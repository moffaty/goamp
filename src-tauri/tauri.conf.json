{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GOAMP",
  "version": "0.1.0",
  "identifier": "com.goamp.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GOAMP",
        "width": 275,
        "height": 464,
        "minWidth": 275,
        "minHeight": 116,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
