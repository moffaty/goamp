{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GOAMP",
  "version": "0.1.0",
  "identifier": "com.goamp.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GOAMP",
        "width": 275,
        "height": 464,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5MTc1Q0M5M0Q2QTMyNzUKUldSMU1tbzl5VndYK2ZqT0d4M0ZTclpEUEhHWUhIODcvbUpZV2pRUzUvWFpGQkdxcU00aGdSWGEK",
      "endpoints": [
        "https://github.com/nicify/goamp/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/yt-dlp", "binaries/goamp-node"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
