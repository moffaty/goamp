{
  "name": "goamp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:win": "tauri build --target x86_64-pc-windows-msvc --runner cargo-xwin --no-bundle",
    "postinstall": "lefthook install",
    "lint": "tsc --noEmit",
    "lint:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings"
  },
  "dependencies": {
    "@aptabase/web": "^0.5.0",
    "@sentry/browser": "^10.45.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "jszip": "^3.10.1",
    "music-metadata-browser": "^2.5.10",
    "webamp": "^1.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "lefthook": "^2.1.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}